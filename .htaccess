<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect all traffic to the public directory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Protect sensitive files in the root
<FilesMatch "^\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|Procfile|nixpacks\.toml|Plan\.md|artisan$">
    Order allow,deny
    Deny from all
</FilesMatch>
